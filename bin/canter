#!/usr/bin/env sh
DIR="$(cd "$(dirname "$0")" && pwd)"
LOCAL_BUN="$DIR/../node_modules/.bin/bun"
if [ -x "$LOCAL_BUN" ]; then
  BUN="$LOCAL_BUN"
elif command -v bun >/dev/null 2>&1; then
  BUN="bun"
else
  echo "mosey: could not locate Bun runtime." >&2
  echo "Try reinstalling: npm install -g mosey" >&2
  exit 1
fi
exec "$BUN" run "$DIR/../src/cli.ts" "$@"
